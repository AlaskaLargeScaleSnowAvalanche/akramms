    steps likely depends on this."""

    parseds = akramms.parse.parse_args(args.spec)
    akdf0 = resolve.resolve_to(parseds, 'exp', realized=False)

    for exp,_ in akdf0.groupby('exp'):
        expmod = akramms.parse.load_expmod(exp)

        makefile = make.Makefile()
        makefile.add(r_experiment.r_active_domains(expmod))
        makefile.generate(os.path.join(expmod.dir, 'init_mk'), run=True, ncpu=1)

