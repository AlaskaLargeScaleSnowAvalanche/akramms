@subcommand([
    argument('spec', nargs='*', help='Items to feed to avalanche spec parser'),
])
def step2(args):
    """Create required DEMs, Forest files, scene definitions, etc.
    NO Proprietary Software in this step, it can run with high levels of parallelism."""

    parseds = akramms.parse.parse_args(args.spec)
    akdf0 = resolve.resolve_to(parseds, 'combo', realized=False)

    for exp,akdf1 in akdf0.groupby('exp'):
        expmod = akramms.parse.load_expmod(exp)
        add_experiment_fn = getattr(expmod, 'add_experiment')    # Select out a DEM tile

        # Add the experiment and combos
        makefile = make.Makefile()
        # This calls through to r_prepare.prepare_scene_rule()
        add_experiment_fn(makefile, akdf1.combo.tolist())
        makefile.generate(expmod.dir / 'init_mk', run=True, ncpu=config.setup_ncpu)


@subcommand([
    argument('spec', nargs='*', help='Items to feed to avalanche spec parser'),
])
def step3(args):
    """Go through RAMMS Stage 0 and 1: ArcGIS and eCognition, setting up RAMMS scenes to run.  Then run RAMMS stage 0 and 1 on each scene."""
    import setuptools
    from akramms.util import harnutil
    from akramms import r_prepare,r_ecog,r_pra_post

    # ------------
    # Make sure the domain finder C++ code is compiled. (needed for RAMMS Stage 1)
    setup_py = os.path.join(harnutil.HARNESS, 'akramms', 'setup.py')
    prefix = os.path.join(harnutil.HARNESS, 'akramms', 'inst')
    cmd = ['install', '--prefix', prefix]
    print('setup.py ', cmd)
    setuptools.sandbox.run_setup(setup_py, cmd)
    # ------------

    parseds = akramms.parse.parse_args(args.spec)
    akdf0 = resolve.resolve_to(parseds, 'combo', realized=False)

    makefile = make.Makefile()

    for exp,akdf1 in akdf0.groupby('exp'):
        expmod = akramms.parse.load_expmod(exp)

        for combo in akdf1.combo.tolist():
            scenedir = expmod.combo_to_scenedir(combo)
            scene_args = params.load(scenedir)

            print(f'----- Adding Scene: {scenedir}')

            # Run ArcGIS script to prepare files for eCognition
            prepare_outputs = makefile.add(r_prepare.data_prep_PRA_rule(scenedir)).outputs

            # Obtain name of neighbor1 graph file for DEM routing network
            # (created above in add_experiment_fn())
            dem_file = scene_args['dem_file']
            dem_filled_file = f'{dem_file[:-4]}_filled.tif'

            # Run eCognition
            makefile.add(r_ecog.rule(scenedir, prepare_outputs, combo.return_period, combo.forest))

            # Post-Process eCognition Output (the pra_file)
            # [f'{scene_name}{For}_{resolution}m_{return_period}{cat_letter}_rel.shp', ...]
            makefile.add(r_pra_post.pra_post_rule(
                scenedir, dem_filled_file, combo.return_period,
                combo.forest, scene_args['snow_file']))

            # and also split into chunks.
            for pra_size in config.allowed_pra_sizes:
                makefile.add(r_pra_post.chunk_rule(
                    scenedir, combo.forest, expmod.resolution,
                    combo.return_period, pra_size))

        makefile.generate(os.path.join(expmod.dir, 'init_mk'), run=True, ncpu=1)

