def rclone_relfiles(src, dest, relfiles, tdir):
    # Rclone the files
        listfile = tdir.filename(prefix='relfiles')
        with open(listfile, 'w') as out:
            for file in relfiles:
                out.write(f'{file}\n')

        # Use that in rclone command
        cmd = ['rclone', '-v', 'copy', '--files-from', listfile,
            src, dest]
        print(' '.join(cmd))
        subprocess.run(cmd, check=True)


@subcommand([
    argument('scene', help='Top-Level scene directory to setup through stages 0 and 1.'),
])
def export(args):
    scene_dir = os.path.abspath(os.path.realpath(args.scene))
    scene_args = params.load(scene_dir)

    with ioutil.TmpDir() as tdir:

        # Top-level files
        snowdepth0_leaf = os.path.split(config.roots.syspath(scene_args['snowdepth_file']))[1]
        snowdepth0_root = os.path.splitext(snowdepth0_leaf)[0]
        snowdepth_leaf = f"{snowdepth0_root}_{scene_args['name']}_select.tif"
        rclone_relfiles(
            os.path.join(config.roots.lookup['PRJ'], scene_args['name']),
            'alaska:AvalancheShare/results/{}'.format(scene_args['name']),
            ['scene.nc', 'scene.cdl', snowdepth_leaf], tdir)


        # File ins maps/ directory
        relfiles = list()
        dir = os.path.join(scene_dir, 'maps')
        for name in os.listdir(dir):
            if name.endswith('.zip'):
                relfiles.append(name)

        rclone_relfiles(
            os.path.join(config.roots.lookup['PRJ'], scene_args['name'], 'maps'),
            'alaska:AvalancheShare/results/{}'.format(scene_args['name']),
            relfiles, tdir)



def main():
    args = cli.parse_args()
    if args.subcommand is None:
        cli.print_help()
    else:
        args.func(args)

main()
