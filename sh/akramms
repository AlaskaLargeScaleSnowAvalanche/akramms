    setup_py = os.path.join(harnutil.HARNESS, 'akramms', 'setup.py')
    prefix = os.path.join(harnutil.HARNESS, 'akramms', 'inst')
    cmd = ['install', '--prefix', prefix]
    print('setup.py ', cmd)
    setuptools.sandbox.run_setup(setup_py, cmd)


    # Load the module (initial 'akramms.' is optional)
    exp_mod = load_exp_mod(sexp_mod)
    exp_dir = get_exp_dir(exp_mod)

    # Load functions from module
    combos_fn = getattr(exp_mod, sexp_fn)     # List the combos

    # Generate the makefile
    makefile = make.Makefile()
    for combo in combos_fn():
        scene_dir = os.path.join(exp_mod.dir, exp_mod.combo_to_scene_subdir(combo))
        print(f'----- Adding Scene: {scene_dir}')
        stages.add_stage0_rules(makefile, scene_dir)

        # RAMMS Stage 1...
#        ramms_dirs_release_files = add_stage1_rules(makefile, scene_dir)

    makefile.generate(os.path.join(exp_dir, 'init_mk'), run=True, ncpu=1)

