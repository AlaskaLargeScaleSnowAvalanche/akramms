@subcommand([
    argument('level', help='What to resolve to', default='chunk'),
    argument('spec', nargs='*', help='Items to feed to avalanche spec parser'),
    argument('--realized', action='store_true',
        help='Only check avalanches with .in.zip / .out.zip files'),
    argument('--update', action='store_true',
        help='Update markers of completion?'),
    argument('--ignore',
        help="Disregard these status codes when aggregating (comma-separated status codes).  At times used with --ignore NOINPUT in some special cases."),
    argument('--dry-run', action='store_true',
        help="Don't actually do the work inside combo archive"),
])
def status(args):
    """Test out parsing and resolving to different levels"""

    if args.ignore is not None:
        ignore_statuses = {joblib.JobStatus._member_map_[x] for x in args.ignore.split(',')}
    else:
        ignore_statuses = {}

    parseds = akramms.parse.parse_args(args.spec)

    # Special optimizations when working at combo level (large scale)
    akdf = resolve.resolve_to(parseds, args.level, realized=False)

    akdf = joblib.add_status(
        akdf, args.level, realized=args.realized, update=args.update, dry_run=args.dry_run, ignore_statuses=ignore_statuses)

#    akdf = pd.concat(dfs).sort_values('combo_order')
#    print(akdf[['combo_order', 'combo', 'combo_status']])
    joblib.print_status(akdf, args.level)
