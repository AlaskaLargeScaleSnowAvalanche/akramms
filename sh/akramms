@subcommand([
    argument('run_dir', help='Run directory to use'),
    argument('id', type=int, help='ID of avalanche in run_dir to run')])
def run(args):
    """Runs a single RAMMS avalanche on the local machine, via Docker"""

    run_dir = os.path.abspath(args.run_dir)
    parts = run_dir.split(os.sep)
    job_name = '{}_{}_{}'.format(parts[-2], parts[-1], args.id)

    r_ramms.submit_job(run_dir, job_name)

@subcommand([
    argument('ramms', help='RAMMS directory or release file to inspect'),
    argument('ids', type=int, nargs='*', help='ID of avalanche in run_dir to run')])
def submit(args):
    """Runs RAMMS for many avalanches"""

    ids = None if len(args.ids) == 0 else args.ids

    # Separate into numeric-only and non-numerica args in the spec
    release_files = rammsutil.get_release_files(args.ramms)
    r_ramms.submit_jobs(release_files, ids=ids)

