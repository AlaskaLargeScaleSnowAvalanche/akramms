@subcommand([argument('ramms', help='RAMMS directory or release file to inspect')])
def ramms(args):
    """Run RAMMS Stage 1 and prerequisites on (possibly) a single release file.  Used for debugging."""
    release_files = rammsutil.get_release_files(args.ramms)
    #print(release_files)

    makefile = make.Makefile()

    for release_file in release_files:
        jb = rammsutil.parse_release_file(release_file)
        scene_dir = jb.scene_dir    # Use this at end
        scene_args = params.load(jb.scene_dir)

        dem_file = scene_args['dem_file']
        dem_filled_file = os.path.splitext(dem_file)[0] + '_filled.tif'

        # Different directory for chull and domain
        chull_file = os.path.join(jb.ramms_dir, 'CHULL', '{}_chull.shp'.format(jb.ramms_name))
        domain_file = os.path.join(jb.ramms_dir, 'DOMAIN', '{}_dom.shp'.format(jb.ramms_name))
        makefile.add(r_domain_builder.domain_rule(
            dem_filled_file, release_file, chull_file, domain_file, min_alpha=18., margin=config.initial_margins[jb.pra_size]))


        # RAMMS Stage 1: IDL Prep
        stage1_outputs = makefile.add(r_ramms.ramms_stage1_rule(
            release_file, dem_file, [release_file, dem_file, domain_file], dry_run=False, submit=config.auto_submit)).outputs

    makefile.generate(os.path.join(scene_dir, 'ramms_mk'), run=True, ncpu=1)

