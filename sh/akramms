        help='Base this on the files on disk?'),
])
def parse(args):

    parseds = akramms.parse.parse_args(args.avals)

    kwargs = {'realized': args.realized}
    if args.scenetype is not None:
        kwargs['scenetypes'] = set(args.scenetype)

    akdf = resolve.resolve_to(parseds, args.level, **kwargs)
    print('=========================>>> akdf')
    print(akdf)

    for tup in akdf.itertuples():
        print(tup)
    return


@subcommand([
    argument('avals', nargs='*', help='Items to feed to avalanche spec parser'),
    argument('-f', '--filter', type=str,
        help='Filter to apply, must return True to include, False to exclude.  See avalfilter.py'),
    argument('-o', '--output',
        help='Name of query file to write'),
])
def query(args):
    from akramms import avalquery,avalfilter

    if args.filter is not None:
        filter_in = exputil.parse_filter(args.filter, 'akramms.avalfilter')
    else:
        filter_in = avalfilter.all

    aspecs, nc_fnames0 = avalparse.parse_aval_specs(args.avals)
    aspecs = avalquery.normalize(aspecs)
    nc_fnames, extent = avalquery.query(aspecs, nc_fnames0, filter_in_fn=filter_in)

    # Get exp_mod
    if len(aspecs) > 0:
        sexp_mod = aspecs[0].exp_mod.name
    else:
        # Get exp_mod from the .nc file
        with netCDF4.Dataset(nc_fnames[0]) as nc:
            sexp_mod = nc.variables['provenance'].exp_mod

    # Write query results to file
    if args.output is not None:
        with open(args.output, 'wb') as out:
            # Query results
            pickle.dump(sexp_mod, out)
            pickle.dump(extent, out)
            pickle.dump(nc_fnames, out)

            # Parsed but unprocessed query
            pickle.dump(aspecs, out)
            pickle.dump(nc_fnames0, out)


    print('============ AvalTuple Specs')
    for aspec in aspecs:
        print(aspec)
    print('============ nc_fnames')
    for ncf in nc_fnames:
        print(ncf)


