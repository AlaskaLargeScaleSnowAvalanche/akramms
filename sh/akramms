# https://stackoverflow.com/questions/51585110/how-to-encode-a-text-stream-into-a-byte-stream-in-python-3
@subcommand([
    argument('ramms', help='RAMMS directory or release file to inspect'),
    argument('id', type=int, help='ID of avalanche in run_dir to inspect'),
    argument('ext', default='.out.log', help='Extension of filename to  cat')])
def less(args):
    stdout0 = sys.stdout
    try:
        less = subprocess.Popen(['less'], stdin=subprocess.PIPE)
        
        #sys.stdout = codecs.getwriter('utf-8')(less.stdin)
        r_ramms.cat(args.ramms, [args.id], ext=args.ext, out_bytes=less.stdin)
        less.communicate()
    finally:
        sys.stdout = stdout0

