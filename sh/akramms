experiment_specRE = re.compile(r'([^.]+)\.([^.]+)$')
def _parse_experiment_spec(spec):
    match = experiment_specRE.match(spec)
    return (match.group(1), match.group(2))

@subcommand([
    argument('experiment-spec', type=_parse_experiment_spec,
        help='Python module and combo function describing the experiment, eg: e_alaska.juneau'),
#    argument('-c', '--combos', default='full',
#        help='Name of combo-generating function'),
])
def step2(args):
    """Create required DEMs, Forest files, scene definitions, etc.
    NO Proprietary Software in this step, it can run with high levels of parallelism."""

    sexp_mod, sexp_fn = getattr(args, 'experiment-spec')

    # Load the module (initial 'akramms.' is optional)
    exp_mod = load_exp_mod(sexp_mod)
    exp_dir = get_exp_dir(exp_mod)

    # Load functions from module
    combos_fn = getattr(exp_mod, sexp_fn)     # List the combos
    add_experiment_fn = getattr(exp_mod, 'add_experiment')    # Select out a DEM tile
    #add_combo_fn = getattr(exp_mod, 'add_combo')    # Comobs to rules

    # Generate the makefile
    makefile = make.Makefile()

    # Add the experiment and combos
    add_experiment_fn(makefile, combos_fn())

    makefile.generate(os.path.join(exp_dir, 'init_mk'), run=True, ncpu=config.setup_ncpu)


@subcommand([
    argument('experiment-spec', type=_parse_experiment_spec,
        help='Python module and combo function describing the experiment, eg: e_alaska.juneau'),
])
