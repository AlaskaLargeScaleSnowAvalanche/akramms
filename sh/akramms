@subcommand(name='overrun', args=[
    argument('spec', nargs='*', help='Items to feed to avalanche spec parser'),
    argument('--block', action='store_true',
        help="Wait for combos to finish running then submit overruns (rather than quitting without submitting)"),
    argument('--ignore',
        help="Run resubmit process even if some avalanches have NOINPUT status (because RAMMS Stage 1 failed to process them)"),
    argument('--force', action='store_true',
        help="Run overrun processing even if combo is not yet finished."),
    argument('--dry-run', action='store_true',
        help="Don't actually do the work"),
])
def xoverrun(args):
    """Resubmits overruns"""
    # Find the overruns
    parseds = akramms.parse.parse_args(args.spec)
    akdf0 = resolve.resolve_to(parseds, 'combo', realized=False, scenetypes={'x', 'arc'})

    if args.ignore is not None:
        ignore_statuses = {joblib.JobStatus._member_map_[x] for x in args.ignore.split(',')}
        update = False    # Don't permanently updates tatus based on ignoring certain status codes
    else:
        ignore_statuses = {}
        update = True

    # Process overruns one combo at a time for lower latency on large experiments
    for ix in range(len(akdf0)):
        akdf1 = akdf0.iloc[[ix],:]    # akdf1 is just one row of akdf0
        overrun.resubmit(akdf1, dry_run=args.dry_run, block=args.block, update=update, ignore_statuses=ignore_statuses)
