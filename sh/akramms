@subcommand(name='overrun', args=[
    argument('spec', nargs='*', help='Items to feed to avalanche spec parser'),
    argument('--sync', action='store_true',
        help="Wait for combos to finish running then submit overruns (rather than quitting without submitting)"),
    argument('--dry-run', action='store_true',
        help="Don't actually do the work"),
])
def xoverrun(args):
    """Resubmits overruns"""
    # Find the overruns
    parseds = akramms.parse.parse_args(args.spec)
#    akdf0 = resolve.resolve_to(parseds, 'id', realized=True, stage='out', scenetypes={'x'})
    akdf0 = resolve.resolve_to(parseds, 'combo', realized=False, scenetypes={'x', 'arc'})

    # Process overruns one combo at a time for lower latency on large experiments
    for ix in range(len(akdf0)):
        akdf1 = akdf0.iloc[[ix],:]    # akdf1 is just one row of akdf0
        overrun.resubmit(akdf1, dry_run=args.dry_run, sync=args.sync)
