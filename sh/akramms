def all_equal(iterable):
    g = groupby(iterable)
    return next(g, True) and not next(g, False)

@subcommand(name='mosaic', args=[
    argument('spec', nargs='*', help='Items to feed to avalanche spec parser.'),
    argument('-s', '--save', help='Name of query file to write to'),
    argument('-q', '--query', help='Name of query file to read from.  If set, then spec is ignored'),
    argument('-o', '--output', required=True, help='Name of Mosaic output file to write'),
    argument('--limit', type=int,
        help='Limit number of avalanches processed (for DEBUGGING)'),
    argument('--overrun', action='store_true',
        help="Mosaic archived overrun avalanches?"),
    argument('--extent', '-e', required=False,
        help="Designation of extent of final mosiac"),
    argument('--margin', '-m', type=int, required=False,
        help="Margin to add to extent [m]"),
    argument('--dry-run', action='store_true',
        help="Don't actually do the work"),
])
def xmosaic(args):
    from akramms import mosaic

    run_setup_py()

    # Get the avalanches and extent to mosaic
    if args.query is None:
        # Identify archived avalanches for use in the mosaic
        parseds = akramms.parse.parse_args(args.spec)
        akdf = resolve.resolve_to(parseds, 'combo', realized=True, scenetypes={'arc'})

        # Make sure they all use the same experiment
        # (Because extents are queried from the experiment definition file)
        assert all(x == akdf.exp[0] for x in akdf.exp)
        expmod = akramms.parse.load_expmod(akdf.exp[0])

        extent,akdf = avalquery.query(akdf, args.extent, include_overruns=args.overrun, scenetypes='arc', margin=args.margin)

        if args.save is not None:
            with open(args.save, 'wb') as out:
                pickle.dump(expmod.name, out)
                pickle.dump(extent, out)
                pickle.dump(akdf, out)
    else:
        with open(args.query, 'rb') as fin:
            exp = pickle.load(out)
            expmod = parse.load_expmod(exp)
            extent = pickle.load(out)
            akdf = pickle.load(out)


    # Do mosaic
    res = expmod.resolution
    gridG = expmod.gridD.global_grid(res, res)
#    gridM = expmod.gridD.sub(113,45, res, res)    # Could be arbitrary rectangle
    gridM = expmod.gridD.subgrid(extent[0], extent[1], extent[2], extent[3], res, res)


    print(akdf[['exp', 'combo','id']])
    print(f'Extent: {extent}')

    if args.dry_run or (args.output is None):
        print('Dry Run, not going further')
        return

    ofname = args.output
    if not ofname.endswith('.zip'):
        raise ValueError('--output must specify a .zip file')


    with ioutil.TmpDir(tdir='tmp', remove=False) as tdir:
        mosaic.mosaic_avals(gridM, akdf.avalfile.tolist(), args.output, tdir)


