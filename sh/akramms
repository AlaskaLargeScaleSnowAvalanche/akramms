import argparse,itertools,os,subprocess
from dggs.avalanche import ramms

# ------------------------------------------------------------------------
# https://mike.depalatis.net/blog/simplifying-argparse.html
# https://gist.github.com/mivade/384c2c41c3a29c637cb6c603d4197f9f

cli = argparse.ArgumentParser()
subparsers = cli.add_subparsers(dest="subcommand")

def argument(*name_or_flags, **kwargs):
    """Convenience function to properly format arguments to pass to the
    subcommand decorator.
    """
    return (list(name_or_flags), kwargs)

def subcommand(args=[], parent=subparsers):
    def decorator(func):
        parser = parent.add_parser(func.__name__, description=func.__doc__)
        for arg in args:
            parser.add_argument(*arg[0], **arg[1])
        parser.set_defaults(func=func)
    return decorator
# ------------------------------------------------------------------------

@subcommand([argument('ramms', help='RAMMS directory or release file to inspect')])
def ps(args):
    """Provides status of RAMMS avalanches"""
    release_files = ramms.get_release_files(args.ramms)

    df = ramms.job_statuses(release_files)
    ramms.print_job_statuses(df)

@subcommand([
    argument('run_dir', help='Run directory to use'),
    argument('id', type=int, help='ID of avalanche in run_dir to run')])
def run(args):
    """Runs a single RAMMS avalanche on the local machine, via Docker"""

    run_dir = os.path.abspath(args.run_dir)
    parts = run_dir.split(os.sep)
    job_name = '{}_{}_{}'.format(parts[-2], parts[-1], args.id)

    ramms.submit_job(run_dir, job_name)

@subcommand([
    argument('ramms', help='RAMMS directory or release file to inspect'),
    argument('ids', type=int, nargs='*', help='ID of avalanche in run_dir to run')])
def submit(args):
    """Runs RAMMS for many avalanches"""

    ids = None if len(args.ids) == 0 else args.ids

    # Separate into numeric-only and non-numerica args in the spec
    release_files = ramms.get_release_files(args.ramms)
    ramms.submit_jobs(release_files, ids=ids)

@subcommand([
    argument('ramms', help='RAMMS directory or release file to inspect'),
    argument('ids', type=int, nargs='*', help='ID of avalanche in run_dir to run')])
def enlarge(args):
    """Enlarges domain of jobs that overran"""

    ids = None if len(args.ids) == 0 else args.ids

    # Separate into numeric-only and non-numerica args in the spec
    release_files = ramms.get_release_files(args.ramms)
    ramms.enlarge_domains(release_files, ids=ids)

